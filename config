ngx_addon_name=ngx_http_autocert_module

# Test-only seed directives (autocert_test_challenge / autocert_test_alpn) are
# compiled in ONLY when AUTOCERT_TEST=1 is exported at configure time (CI e2e
# that needs to seed a challenge before the order flow runs). Production builds
# omit them entirely, so a stray/templated directive cannot inject a forged key
# authorization the :80 handler would serve.
if [ "${AUTOCERT_TEST:-}" = "1" ]; then
    CFLAGS="$CFLAGS -DNGX_AUTOCERT_TEST=1"
fi

# One module ships from this addon:
#   - ngx_http_autocert_module : HTTP module; directives, config model, crypto,
#                                per-SNI cert serving, AND the ACME engine driver
#                                (ngx_autocert_driver.c) which runs on worker 0
#                                via the module's init_process hook.
#
# The dedicated privileged helper process (the old CORE ngx_autocert_process
# module) is gone: the ACME state machine is process-agnostic and now runs on
# worker 0, matching angie's native acme and the official Rust nginx-acme.
#
# Built as a dynamic module (load_module). The else branch is the legacy
# static-link path for pre-1.9.11 nginx that lacks $ngx_module_link / auto/module.

AUTOCERT_SRCS="$ngx_addon_dir/src/ngx_http_autocert_module.c \
               $ngx_addon_dir/src/ngx_autocert_driver.c \
               $ngx_addon_dir/src/ngx_autocert_acme.c \
               $ngx_addon_dir/src/ngx_autocert_json.c \
               $ngx_addon_dir/src/ngx_autocert_account.c \
               $ngx_addon_dir/src/ngx_autocert_order.c \
               $ngx_addon_dir/src/ngx_autocert_challenge.c \
               $ngx_addon_dir/src/ngx_autocert_alpn.c \
               $ngx_addon_dir/src/ngx_autocert_serve.c \
               $ngx_addon_dir/src/ngx_http_autocert_crypto.c \
               $ngx_addon_dir/src/ngx_autocert_conf.c"

AUTOCERT_DEPS="$ngx_addon_dir/src/ngx_autocert_driver.h \
               $ngx_addon_dir/src/ngx_autocert_acme.h \
               $ngx_addon_dir/src/ngx_autocert_json.h \
               $ngx_addon_dir/src/ngx_autocert_account.h \
               $ngx_addon_dir/src/ngx_autocert_order.h \
               $ngx_addon_dir/src/ngx_autocert_challenge.h \
               $ngx_addon_dir/src/ngx_autocert_alpn.h \
               $ngx_addon_dir/src/ngx_autocert_serve.h \
               $ngx_addon_dir/src/ngx_http_autocert_crypto.h \
               $ngx_addon_dir/src/ngx_autocert_shared.h \
               $ngx_addon_dir/src/ngx_http_autocert_conf.h"

if test -n "$ngx_module_link"; then
    ngx_module_type=HTTP
    ngx_module_name=ngx_http_autocert_module
    ngx_module_srcs="$AUTOCERT_SRCS"
    ngx_module_libs="-lssl -lcrypto"
    ngx_module_deps="$AUTOCERT_DEPS"
    . auto/module
else
    HTTP_MODULES="$HTTP_MODULES ngx_http_autocert_module"
    NGX_ADDON_SRCS="$NGX_ADDON_SRCS $AUTOCERT_SRCS"
    NGX_ADDON_DEPS="$NGX_ADDON_DEPS $AUTOCERT_DEPS"
    CORE_LIBS="$CORE_LIBS -lssl -lcrypto"
fi
